<section class="relative w-full overflow-hidden">

  <!-- LCP BILD (synlig direkt) -->
  <img
    src="/images/ventilation.webp"
    alt="Ventilationsservice i Sverige"
    width="1200"
    height="800"
    fetchpriority="high"
    class="w-full h-[40vh] md:h-[50vh] object-cover"
  />

  <!-- VIDEO laddas ovanpå -->
  <video
    class="absolute inset-0 w-full h-full object-cover"
    autoplay
    loop
    muted
    playsinline
    preload="none"
    poster="/images/ventilation.webp"
  >
    <source src="/videos/anvlppF.mp4" type="video/mp4" />
  </video>

</section>

<script is:client>
  // Wait for the DOM to be fully loaded
  window.addEventListener('DOMContentLoaded', () => {
    const video = document.getElementById('contact-video');
    if (!video) return;

    // Ensure it's muted for autoplay
    video.muted = true;

    // Try to play immediately
    video.play().catch(() => {
      // If autoplay is blocked, play when visible
      const observer = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            video.play().catch(() => {});
            observer.disconnect();
          }
        },
        { threshold: 0.25 }
      );
      observer.observe(video);
    });
  });
</script>