---
const slides = [
  {
    image: "/images/fonster.webp",
    title: "Välkommen till Ecoventilation",
    description: "Vi hjälper dig att optimera din ventilation för en bättre inomhusmiljö och lägre energikostnader.",
    
  },
  {
    image: "/images/hood.webp",
title: "Imkanalsrengöring",
description: "Professionell rengöring av imkanaler för att minska brandrisk och säkerställa god ventilation i hemmen.",
    
  },
  {
    image: "/images/ventilation.webp",
    title: "Ventilationsservice",
    description: "Regelbunden rengöring och underhåll för optimal inomhusluftkvalitet.",
    
  },
    {
    image: "/images/ftxx.webp",
   title: "FTX-service",
description: "Service och underhåll av FTX-ventilation för optimal värmeåtervinning och energieffektiv inomhusmiljö.",
  
  },
  {
    image: "/images/sink.webp",
    title: "Avloppsservice",
    description: "Specialister på avloppsproblem – från akuta stopp till förebyggande underhåll.",
  
  }

];
---
<section class="relative h-[85vh] min-h-[600px] max-h-[800px] w-full overflow-hidden rounded-2xl md:rounded-3xl shadow-2xl" id="hero-carousel">

  {slides.map((slide, idx) => (
    <div class="absolute inset-0 transition-opacity duration-700 rounded-2xl md:rounded-3xl overflow-hidden" data-slide={idx}>
      <img src={slide.image} loading="lazy" alt={slide.title} class="object-cover w-full h-full" />
      <div class="absolute inset-0 bg-black/25 z-10" />
      <div class="absolute inset-0 z-20 flex flex-col items-center justify-center px-4 text-center">
        <h1 class="mb-6 text-4xl font-bold text-white drop-shadow-lg md:text-5xl lg:text-6xl">{slide.title}</h1>
        <p class="mb-8 max-w-3xl text-lg text-white/90 md:text-xl lg:text-2xl">{slide.description}</p>
       
      </div>
    </div>
  ))}

  <!-- Navigation arrows -->
  <button id="prevSlide" class="absolute left-8 top-1/2 z-30 hidden h-14 w-14 -translate-y-1/2 items-center justify-center rounded-full border-2 border-[#3498DB]/50 bg-[#2C3E50]/70 transition-transform hover:scale-110 hover:border-[#3498DB] md:flex">‹</button>
  <button id="nextSlide" class="absolute right-8 top-1/2 z-30 hidden h-14 w-14 -translate-y-1/2 items-center justify-center rounded-full border-2 border-[#3498DB]/50 bg-[#2C3E50]/70 transition-transform hover:scale-110 hover:border-[#3498DB] md:flex">›</button>

  <!-- Dots -->
  <div class="absolute bottom-10 left-0 right-0 z-30 flex justify-center gap-3">
    {slides.map((_, idx) => (
      <button class="h-3 w-3 rounded-full border-2 transition-all" data-dot={idx}></button>
    ))}
  </div>

  <!-- Progress bar - now with border radius at bottom -->
  <div class="absolute bottom-0 left-0 z-30 h-1 w-full bg-white/20 overflow-hidden rounded-b-2xl md:rounded-b-3xl">
    <div class="h-full bg-[#3498DB]" id="progress-bar" style="width:0%"></div>
  </div>
</section>

<script is:inline>
  (() => {
    const slides = document.querySelectorAll('#hero-carousel [data-slide]');
    const dots = document.querySelectorAll('#hero-carousel [data-dot]');
    const progressBar = document.getElementById('progress-bar');
    const total = slides.length;
    let current = 0;
    let transitioning = false;

    function showSlide(index) {
      if (transitioning) return;
      transitioning = true;
      slides.forEach((s, i) => {
        s.style.opacity = i === index ? '1' : '0';
        s.style.zIndex = i === index ? '20' : '10';
      });
      dots.forEach((d, i) => {
        d.classList.toggle('scale-125', i === index);
        d.style.borderColor = i === index ? '#3498DB' : 'rgba(255,255,255,0.6)';
        d.style.backgroundColor = i === index ? '#3498DB' : '';
      });
      progressBar.style.width = `${((index+1)/total)*100}%`;
      setTimeout(() => { transitioning = false; }, 400);
      current = index;
    }

    function nextSlide() { showSlide((current+1)%total); }
    function prevSlide() { showSlide((current-1+total)%total); }

    document.getElementById('nextSlide').addEventListener('click', nextSlide);
    document.getElementById('prevSlide').addEventListener('click', prevSlide);
    dots.forEach((dot, i) => dot.addEventListener('click', () => showSlide(i)));

    // Auto slide every 5s
    setInterval(() => { if (!transitioning) nextSlide(); }, 5000);

    // Initial
    showSlide(0);
  })();
</script>