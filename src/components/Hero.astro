        <span class="text-[#1ABC9C] text-xl">✓</span> Snabb service
      </div>
      <div class="flex items-center gap-2 bg-white/10 px-6 py-3 rounded-2xl backdrop-blur-sm border border-[#3498DB]/30 transition-transform hover:-translate-y-1">
        <span class="text-[#1ABC9C] text-xl">✓</span> Erfaren personal
      </div>
    </div>
