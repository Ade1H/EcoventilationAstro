---
// Chat.astro - Tailwind CSS version för Ecoventilation
// Färg: Racing Navy Blue (#1C2E4A)
---

<div class="fixed bottom-6 right-6 z-[9999] font-sans" id="chatContainer">
  <!-- Chat Bubble Button -->
  <button 
    class="flex items-center gap-2 bg-[#1C2E4A] text-white border-none px-6 py-3 rounded-full text-base font-medium cursor-pointer shadow-lg hover:bg-[#0F1E33] hover:scale-105 transition-all duration-200" 
    id="chatBubble"
  >
    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
    <span class="inline-block">Chatt</span>
  </button>

  <!-- Chat Window -->
  <div 
    class="absolute bottom-0 right-0 w-[380px] h-[600px] bg-white rounded-xl shadow-2xl hidden flex-col overflow-hidden animate-[slideUp_0.3s_ease] data-[open=true]:flex" 
    id="chatWindow"
  >
    <!-- Header -->
    <div class="flex justify-between items-center px-5 py-4 bg-[#1C2E4A] text-white">
      <div class="flex items-center gap-3">
        <div class="w-2.5 h-2.5 bg-emerald-500 rounded-full animate-pulse"></div>
        <div>
          <h3 class="text-base font-semibold m-0">Ecoventilation</h3>
          <span class="text-xs opacity-90">Svarar innom kort </span>
        </div>
      </div>
      <button class="bg-none border-none text-white cursor-pointer p-1 rounded-md hover:bg-white/10 transition-colors" id="closeChat">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Messages -->
    <div class="flex-1 p-5 overflow-y-auto bg-gray-50 flex flex-col gap-4" id="chatMessages">
      <div class="flex gap-3 max-w-[85%]">
        <div class="flex-shrink-0 w-9 h-9">
          <div class="w-full h-full bg-[#1C2E4A] rounded-full shadow-sm"></div>
        </div>
        <div class="flex flex-col gap-1">
          <div class="text-xs font-semibold text-gray-900 mb-0.5">Ecoventilation</div>
          <div class="py-3 px-4 bg-white rounded-2xl rounded-bl shadow-sm text-sm text-gray-900 break-words">
            Hej! 👋 Välkommen till Ecoventilation. 
            Hur kan jag hjälpa dig med ventilation idag?
          </div>
          <div class="text-xs text-gray-500 mt-0.5">Nu</div>
        </div>
      </div>
    </div>

    <!-- Typing Indicator -->
    <div class="hidden items-center gap-2 px-5 py-3 bg-white border-t border-gray-200 text-xs text-gray-500" id="typingIndicator">
      <div class="flex gap-1">
        <span class="w-1.5 h-1.5 bg-gray-500 rounded-full animate-[typing_1.4s_infinite]"></span>
        <span class="w-1.5 h-1.5 bg-gray-500 rounded-full animate-[typing_1.4s_infinite] delay-200"></span>
        <span class="w-1.5 h-1.5 bg-gray-500 rounded-full animate-[typing_1.4s_infinite] delay-400"></span>
      </div>
      <span>Ecoventilation skriver...</span>
    </div>

    <!-- Input Area -->
    <div class="p-4 bg-white border-t border-gray-200">
      <div class="flex gap-2 items-center bg-gray-50 border border-gray-200 rounded-full px-4 py-1 transition-colors focus-within:border-[#1C2E4A] focus-within:shadow-[0_0_0_3px_rgba(28,46,74,0.1)]">
        <input 
          type="text" 
          id="messageInput" 
          placeholder="Skriv din fråga här..."
          autocomplete="off"
          class="flex-1 border-none bg-transparent py-3 text-sm outline-none"
        />
        <button 
          class="w-10 h-10 flex items-center justify-center bg-[#1C2E4A] text-white border-none rounded-full cursor-pointer transition-all hover:bg-[#0F1E33] hover:scale-105 disabled:opacity-50 disabled:cursor-not-allowed" 
          id="sendButton" 
          disabled
        >
          <svg class="w-4.5 h-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>
          </svg>
        </button>
      </div>
      <div class="flex justify-between items-center mt-2 text-[11px] text-gray-500 px-2">
        <span class="text-xs opacity-90">Svarar innom kort </span>
        <a href="/contact" class="text-[#1C2E4A] no-underline font-medium hover:underline">Annars kontakta oss här →</a>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const chatBubble = document.getElementById('chatBubble');
    const chatWindow = document.getElementById('chatWindow');
    const closeChat = document.getElementById('closeChat');
    const messageInput = document.getElementById('messageInput');
    const sendButton = document.getElementById('sendButton');
    const chatMessages = document.getElementById('chatMessages');
    const typingIndicator = document.getElementById('typingIndicator');

    // Open/close chat
    chatBubble?.addEventListener('click', () => {
      chatWindow.classList.add('flex');
      chatWindow.classList.remove('hidden');
      chatBubble.style.display = 'none';
    });

    closeChat?.addEventListener('click', () => {
      chatWindow.classList.remove('flex');
      chatWindow.classList.add('hidden');
      chatBubble.style.display = 'flex';
    });

    // Enable/disable send button based on input
    messageInput?.addEventListener('input', () => {
      sendButton.disabled = !messageInput.value.trim();
    });

    // Send message on Enter
    messageInput?.addEventListener('keypress', (e) => {
      if (e.key === 'Enter' && !sendButton.disabled) {
        sendMessage();
      }
    });

    // Send message on button click
    sendButton?.addEventListener('click', sendMessage);

    async function sendMessage() {
      const message = messageInput.value.trim();
      if (!message) return;

      // Add user message
      addMessage(message, 'user');
      
      // Clear input
      messageInput.value = '';
      sendButton.disabled = true;

      // Show typing indicator
      typingIndicator.classList.add('flex');
      typingIndicator.classList.remove('hidden');

      try {
        const response = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message })
        });

        const data = await response.json();
        
        // Hide typing indicator
        typingIndicator.classList.remove('flex');
        typingIndicator.classList.add('hidden');
        
        // Add bot response
        addMessage(data.response, 'bot');
      } catch (error) {
        typingIndicator.classList.remove('flex');
        typingIndicator.classList.add('hidden');
        addMessage('Tyvärr uppstod ett tekniskt fel. Försök igen eller ring oss!', 'bot error');
      }
    }

    function addMessage(text, sender) {
      const messageDiv = document.createElement('div');
      
      const time = new Date().toLocaleTimeString('sv-SE', { 
        hour: '2-digit', 
        minute: '2-digit' 
      });

      if (sender === 'user') {
        messageDiv.className = 'flex gap-3 max-w-[85%] ml-auto flex-row-reverse';
        messageDiv.innerHTML = `
          <div class="flex flex-col gap-1 items-end">
            <div class="py-3 px-4 bg-[#1C2E4A] text-white rounded-2xl rounded-br shadow-sm text-sm break-words">
              ${escapeHtml(text)}
            </div>
            <div class="text-xs text-gray-500 mt-0.5">${time}</div>
          </div>
        `;
      } else {
        messageDiv.className = 'flex gap-3 max-w-[85%]';
        messageDiv.innerHTML = `
          <div class="flex-shrink-0 w-9 h-9">
            <div class="w-full h-full bg-[#1C2E4A] rounded-full shadow-sm"></div>
          </div>
          <div class="flex flex-col gap-1">
            <div class="text-xs font-semibold text-gray-900 mb-0.5">Ecoventilation</div>
            <div class="py-3 px-4 bg-white rounded-2xl rounded-bl shadow-sm text-sm text-gray-900 break-words">
              ${escapeHtml(text)}
            </div>
            <div class="text-xs text-gray-500 mt-0.5">${time}</div>
          </div>
        `;
      }
      
      chatMessages.appendChild(messageDiv);
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    // Helper to escape HTML
    function escapeHtml(unsafe) {
      return unsafe
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }
  });
</script>

<style>
  /* Tailwind CSS direktiv - lägg dessa i din globala CSS-fil */
  @tailwind base;
  @tailwind components;
  @tailwind utilities;

  /* Anpassade animationer */
  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes typing {
    0%, 60%, 100% {
      transform: translateY(0);
    }
    30% {
      transform: translateY(-4px);
    }
  }

  .delay-200 {
    animation-delay: 0.2s;
  }

  .delay-400 {
    animation-delay: 0.4s;
  }

  /* För dark mode - via Tailwind */
  @media (prefers-color-scheme: dark) {
    .dark\:bg-gray-800 {
      background-color: #1f2937;
    }
    .dark\:bg-gray-900 {
      background-color: #111827;
    }
    .dark\:text-white {
      color: #ffffff;
    }
    .dark\:text-gray-300 {
      color: #d1d5db;
    }
    .dark\:border-gray-700 {
      border-color: #374151;
    }
  }
</style>