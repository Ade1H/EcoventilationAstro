---
// HeroVideoSection.astro
---
<section class="relative w-full min-h-screen overflow-hidden bg-black">

  <!-- VIDEO -->
  <video
    id="hero-video"
    class="absolute inset-0 w-full h-full object-cover"
    autoplay
    loop
    muted
    playsinline
    preload="metadata"
    poster="/images/EcHeroE.webp"
  >
    <source src="/videos/ajor.mp4" type="video/mp4" />
    Din webbläsare stöder inte video-taggen.
  </video>

  <!-- DARK OVERLAY -->
  <div class="absolute inset-0 bg-black/10 z-10"></div>

  <!-- CONTENT -->
  <div class="relative z-20 flex flex-col items-center justify-center text-center px-4 min-h-screen">
    <div class="max-w-3xl">

      <!-- HEADLINE -->
      <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold text-white drop-shadow-lg mb-6 leading-tight">
        Renare Luft. Lägre Energikostnader.
      </h1>

      <!-- SUBHEADLINE -->
      <p class="text-lg md:text-xl text-white/90 mb-8 leading-relaxed">
        Vi hjälper, fastighetsägare och privatpersoner med FTX-service, ventilationsrengöring – snabbt, tryggt och professionellt.
      </p>

      <!-- BUTTONS -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact"
          class="w-full sm:w-auto px-8 py-4 rounded-full text-black font-semibold text-lg bg-gradient-to-r from-[#3498DB] to-[#1ABC9C] shadow-lg hover:shadow-xl transition-all"
        >
          Få kostnadsfri offert
        </a>

        <a
          href="tel:+4620104544"
          class="w-full sm:w-auto px-8 py-4 rounded-full text-white font-semibold text-lg border-2 border-white/70 hover:border-[#1ABC9C] hover:text-[#1ABC9C] transition-all"
        >
           Ring oss direkt
        </a>
      </div>

      <!-- TRUST LINE -->
      <p class="text-white/80 text-sm mt-6">
        ✓ Certifierade tekniker &nbsp; ✓ Snabb respons &nbsp; ✓ Konkurrenskraftiga priser
      </p>

    </div>
  </div>

</section>

<script is:inline>
  const video = document.getElementById('hero-video');
  if (video) {
    video.playbackRate = 1.3;
    video.play().catch(() => console.log('Autoplay blocked.'));
  }
</script>