---
// HeroVideoSection.astro
---
<section class="relative w-full h-screen overflow-hidden bg-black">

  <!-- VIDEO -->
  <video
    id="hero-video"
    class="absolute inset-0 w-full h-full object-cover"
    autoplay
    loop
    muted
    playsinline
    preload="metadata"
    poster="/images/EcHeroE.webp"
  >
    <source src="/videos/serviceVideo.mp4" type="video/mp4" />
    Din webbläsare stöder inte video-taggen.
  </video>

  <!-- OVERLAY -->
  <div class="absolute inset-0 bg-black/25 flex flex-col items-center justify-center z-10 text-center px-4 pointer-events-none">
    <div class="max-w-3xl">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white drop-shadow-lg mb-6">
        Ventilationsrengöring & FTX-service <br /> för ett friskare hem
      </h1>
      <p class="text-lg md:text-xl text-white/90 mb-8 leading-relaxed">
        Ecoventilation hjälper privatpersoner och företag med ventilationsrengöring, FTX-installation, service och avloppsrensning – för bättre inomhusluft och energieffektivitet.
      </p>
    </div>
  </div>

  <!-- BUTTONS -->
  <div class="absolute inset-0 flex items-end justify-center pb-10 z-20 gap-4 flex-wrap">
    <a
      href="/contact"
      class="inline-block px-8 py-3 rounded-full text-black font-semibold text-lg bg-gradient-to-r from-[#3498DB] to-[#1ABC9C] shadow-lg hover:shadow-xl transition-all z-30"
    >
      Begär offert
    </a>
    <a
      href="tel:+4620104544"
      class="inline-block px-8 py-3 rounded-full text-white font-semibold text-lg border-2 border-white/60 hover:border-[#1ABC9C] hover:text-[#1ABC9C] transition-all z-30"
    >
      Ring oss
    </a>
  </div>
</section>

<script is:inline>
  const video = document.getElementById('hero-video');
  if (video) {
    video.playbackRate = 1.5;
    video.play().catch(() => console.log('Autoplay blocked, user interaction needed.'));
  }
</script>
