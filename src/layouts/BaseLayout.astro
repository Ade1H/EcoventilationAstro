---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

// Dynamic props
const { 
  title = "Ecoventilation", 
  description = "Ecoventilation erbjuder professionell ventilationsservice, rensning av imkanaler, FTX-service och avloppsrensning i hela Sverige.", 
  ogImage = "https://www.ecoventilation.se/images/og-image.png" 
} = Astro.props;

const siteUrl = "https://www.ecoventilation.se";
const currentUrl = new URL(Astro.url.pathname, siteUrl).toString();

// Structured Data Object
const schemaData = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Ecoventilation",
  "url": siteUrl,
  "logo": `${siteUrl}/favicon.webp`,
  "image": ogImage,
  "description": description,
  "areaServed": {
    "@type": "Country",
    "name": "Sweden"
  },
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "SE"
  },
  "sameAs": [
    "https://www.facebook.com/profile.php?id=61586090752435",
    "https://www.instagram.com/ecoventilation/"
  ]
};
---

<!DOCTYPE html>
<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={currentUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Ecoventilation" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" href="/favicon.webp" type="image/png" />
    <link rel="apple-touch-icon" href="/favicon.webp" />

    <link rel="sitemap" type="application/xml" title="Sitemap" href={`${siteUrl}/sitemap-index.xml`} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaData)} />
  </head>
  
  <body class="min-h-screen flex flex-col">
    <Navbar />
    
    <main class="flex-1">
      <slot /> </main>
    
    <Footer />

