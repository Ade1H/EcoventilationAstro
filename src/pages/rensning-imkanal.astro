---

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Rensning av Imkanal – Sverige"
  description="Professionell rensning av imkanaler i hela Sverige. Vi minskar brandrisk och förbättrar luftflödet med certifierad service."
>

<main class="max-w-[1200px] mx-auto px-6 py-20 text-gray-800">

<!-- ================= HERO ================= -->

<section class="text-center mb-20">
  <h1 class="text-4xl md:text-5xl font-bold mb-6">
    Rensning av Imkanal
  </h1>

  <p class="text-lg text-gray-600 max-w-3xl mx-auto">
    Imkanalen transporterar bort matos och fett från köket.
    Regelbunden rensning minskar brandrisk och säkerställer effektiv ventilation.
  </p>
</section>

<!-- ================= IMAGES ================= -->

<section class="grid md:grid-cols-2 gap-8 mb-20">
  <img
    src="/images/imkanalTowPer.webp"
    alt="Rensning av imkanal"
    class="rounded-xl w-full h-80 object-cover"
  />

  <img
    src="/images/imK2.webp"
    alt="Professionell rensning av imkanal"
    class="rounded-xl w-full h-80 object-cover"
  />
</section>

<!-- ================= DESCRIPTION ================= -->

<section class="mb-20 space-y-8 text-lg text-gray-600 leading-relaxed">

  <h2 class="text-3xl font-semibold text-gray-800">
    Vad är en imkanal?
  </h2>

  <p>
    Imkanalen är en del av köksventilationen som leder bort fett, ånga och
    matos från spisfläkten.
  </p>

  <p>
    När fett samlas i kanalen ökar brandrisken och luftflödet försämras.
    Regelbunden rengöring är därför avgörande för säker drift.
  </p>

  <p>
    Även om det inte längre är lagkrav för alla privata fastigheter,
    ligger ansvaret hos fastighetsägaren att säkerställa säker funktion.
  </p>

</section>

<!-- ================= KEY FACTS ================= -->

<section class="mb-20">

  <h2 class="text-3xl font-semibold mb-10 text-center">
    Viktiga fakta
  </h2>

  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">

    {[
      "Brandrisk minskar med ren kanal",
      "Bättre och stabilare luftflöde",
      "Rekommenderas minst 1 gång per år",
      "Dokumenterad och säker rensning"
    ].map((item) => (
      <div class="border border-gray-200 rounded-xl p-6 text-lg">
        {item}
      </div>
    ))}

  </div>

</section>

<!-- ================= WARNING SIGNS ================= -->

<section class="mb-20">

  <h2 class="text-3xl font-semibold mb-8 text-center">
    Tecken på att imkanalen behöver rensas
  </h2>

  <div class="border border-gray-200 rounded-xl p-8">
    <ul class="space-y-4 text-lg text-gray-600 list-disc list-inside">
      <li>Matos eller lukt stannar kvar i köket</li>
      <li>Dålig sugkraft från fläkten</li>
      <li>Fettrester på ventiler</li>
      <li>Ovanlig lukt eller rök vid matlagning</li>
    </ul>
  </div>

</section>

<!-- ================= PROCESS ================= -->

<section class="mb-20">

  <h2 class="text-3xl font-semibold mb-8 text-center">
    Så går rensningen till
  </h2>

  <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">

    {[
      { step: "1", title: "Inspektion", text: "Kontroll av kanalens skick" },
      { step: "2", title: "Rengöring", text: "Mekanisk rengöring av fett och beläggningar" },
      { step: "3", title: "Kontroll", text: "Säkerställ korrekt luftflöde" },
      { step: "4", title: "Dokumentation", text: "Rapport av utfört arbete" }
    ].map((item) => (

      <div class="border border-gray-200 rounded-xl p-6 text-center">

        <div class="w-12 h-12 mx-auto mb-4 border border-black rounded-full flex items-center justify-center font-semibold">
          {item.step}
        </div>

        <h3 class="text-lg font-semibold mb-2">
          {item.title}
        </h3>

        <p class="text-gray-600 text-sm">
          {item.text}
        </p>

      </div>

    ))}

  </div>

</section>

<!-- ================= CTA ================= -->

<section class="text-center py-20 border-t border-gray-200">

  <h2 class="text-3xl font-bold mb-6">
    Boka rensning av din imkanal
  </h2>

  <p class="text-gray-600 max-w-2xl mx-auto mb-10 text-lg">
    Kontakta oss för professionell och säker rensning av imkanaler i hela Sverige.
  </p>

  <div class="flex flex-wrap justify-center gap-6">
    <a
      href="/contact"
      class="px-8 py-4 border border-black rounded-lg hover:bg-black hover:text-white transition"
    >
      Kontakta oss
    </a>

    <a
      href="tel:+4620104544"
      class="px-8 py-4 border border-black rounded-lg hover:bg-black hover:text-white transition"
    >
      Ring 020-10 45 44
    </a>
  </div>

</section>

</main>

</BaseLayout>