---
import BaseLayout from "../layouts/BaseLayout.astro";
import cities from "../data/swedish-cities-with-region.json";
import { slugify } from "../utils/slug";

const regions = [...new Set(cities.map(city => city.region))];
---

<BaseLayout
  title="Ventilationsservice i Alla Län i Sverige | Ecoventilation"
  description="Professionell ventilationsservice i alla län i Sverige. Välj ditt län och hitta din kommun."
>

<main class="max-w-6xl mx-auto px-6 py-20">

  <section class="text-center mb-16">
    <h1 class="text-4xl font-bold">
      Ventilationsservice i Sverige
    </h1>

    <p class="mt-4 text-gray-600 text-lg max-w-3xl mx-auto">
      Klicka på ditt län för att se alla kommuner vi erbjuder service i.
    </p>
  </section>

  <section class="grid md:grid-cols-3 gap-6">
    {regions.map(region => {
      const slug = slugify(region);

      return (
        <a
          href={`/region/${slug}`}
          class="border rounded-xl p-6 text-lg font-medium hover:bg-black hover:text-white transition"
        >
          {region}
        </a>
      );
    })}
  </section>

</main>

</BaseLayout>