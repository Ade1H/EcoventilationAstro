---
import Layout from "../layouts/BaseLayout.astro";
---

<Layout title="Referenser | EcoVentilation">

<section class="px-6 md:px-20 py-20 bg-gray-50">

  <div class="max-w-5xl mx-auto">

    <h1 class="text-4xl font-bold mb-6">
      Våra Referenser
    </h1>

    <p class="text-lg text-gray-700 mb-10">
      Här visar vi projekt vi har genomfört samt våra kunders riktiga
      recensioner via Reco.
    </p>

    <!-- 🔵 Dina projekt -->
    <div class="grid md:grid-cols-2 gap-6 mb-16">

      <div class="bg-white shadow-lg rounded-2xl p-6">
        <h3 class="text-xl font-semibold">
          Ventilation – Villa
        </h3>
        <p class="text-gray-600 mt-2">
          Installation av nytt ventilationssystem med energieffektiv lösning.
        </p>
      </div>

      <div class="bg-white shadow-lg rounded-2xl p-6">
        <h3 class="text-xl font-semibold">
          Service – Företagslokal
        </h3>
        <p class="text-gray-600 mt-2">
          Optimering av luftflöde och förbättring av inomhusklimat.
        </p>
      </div>

    </div>

    <!-- 🔥 RECO WIDGET -->
    <div class="mt-10">

      <h2 class="text-2xl font-bold mb-6">
        ⭐ Kundrecensioner via Reco
      </h2>

      <!-- Klistra in Reco embed kod här -->
      <div>
        <!-- RECO EMBED CODE HERE -->
      </div>

    </div>

  </div>

</section>

</Layout>