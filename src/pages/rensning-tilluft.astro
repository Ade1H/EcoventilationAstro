---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Rensning av Tilluft – Gävle & Sverige"
  description="Professionell rengöring av tilluftssystem i hela Sverige. Vi förbättrar luftkvalitet, komfort och energieffektivitet."
>

<main class="max-w-[1200px] mx-auto px-6 py-20 text-gray-800">

<!-- ================= HERO ================= -->

<section class="text-center mb-20">
  <h1 class="text-4xl md:text-5xl font-bold mb-6">
    Rensning av Tilluft
  </h1>

  <p class="text-lg text-gray-600 max-w-3xl mx-auto">
    Ett rent tilluftssystem ger frisk luft, jämn temperatur och bättre inomhuskomfort.
  </p>
</section>

<!-- ================= IMAGES ================= -->

<section class="grid md:grid-cols-2 gap-8 mb-20">
  <img
    src="/images/TillLuft.webp"
    alt="Tilluftsventiler"
    class="rounded-xl w-full h-80 object-cover"
    width="672"
    height="448"
  />

  <img
    src="/images/tilluft.webp"
    alt="Rengöring av tilluftssystem"
    class="rounded-xl w-full h-80 object-cover"
    width="672"
    height="448"
  />
</section>

<!-- ================= DESCRIPTION ================= -->

<section class="mb-20 space-y-8 text-lg text-gray-600 leading-relaxed">

  <h2 class="text-3xl font-semibold text-gray-800">
    Vad är tilluft?
  </h2>

  <p>
    Tilluft tillför frisk utomhusluft till bostaden via ventiler och kanaler.
    Systemet ska vara rent och korrekt justerat för att säkerställa ett hälsosamt inomhusklimat.
  </p>

  <p>
    Smutsiga ventiler och filter kan försämra luftflödet och öka damm,
    allergier och energiförbrukning.
  </p>

</section>

<!-- ================= COMPONENTS ================= -->

<section class="mb-20">

  <h2 class="text-3xl font-semibold mb-10 text-center">
    Delar som rengörs
  </h2>

  <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">

    {[
      "Tilluftsventiler – rengörs och justeras",
      "Kanaler – dammsugs och kontrolleras",
      "Filter – byts eller rengörs",
      "Fläktar & luftfördelning – optimeras"
    ].map((item) => (

      <div class="border border-gray-200 rounded-xl p-6 text-lg">
        {item}
      </div>

    ))}

  </div>

</section>

<!-- ================= BENEFITS ================= -->

<section class="mb-20">

  <h2 class="text-3xl font-semibold mb-10 text-center">
    Fördelar med ren tilluft
  </h2>

  <div class="border border-gray-200 rounded-xl p-8">

    <ul class="space-y-4 text-lg text-gray-600 list-disc list-inside">
      <li>Friskare inomhusluft</li>
      <li>Mindre allergipåverkan</li>
      <li>Bättre luftcirkulation</li>
      <li>Ökad energieffektivitet</li>
    </ul>

  </div>

</section>

<!-- ================= WARNING ================= -->

<section class="mb-20">

  <h2 class="text-3xl font-semibold mb-10 text-center">
    Tecken på att service behövs
  </h2>

  <div class="border border-gray-200 rounded-xl p-8">

    <ul class="space-y-4 text-lg text-gray-600 list-disc list-inside">
      <li>Instängd luft i rummen</li>
      <li>Mycket damm på ytor</li>
      <li>Kondens på fönster</li>
      <li>Försämrad luftkvalitet</li>
    </ul>

  </div>

</section>

<!-- ================= PROCESS ================= -->

<section class="mb-20">

  <h2 class="text-3xl font-semibold mb-10 text-center">
    Så går rengöringen till
  </h2>

  <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">

    {[
      "Inspektion",
      "Rengöring av ventiler",
      "Rengöring av kanaler",
      "Justering & kontroll"
    ].map((step, index) => (

      <div class="border border-gray-200 rounded-xl p-6 text-center">

        <div class="w-12 h-12 mx-auto mb-4 border border-black rounded-full flex items-center justify-center font-semibold">
          {index + 1}
        </div>

        <p class="text-gray-700">{step}</p>

      </div>

    ))}

  </div>

</section>

<!-- ================= CTA ================= -->

<section class="text-center py-20 border-t border-gray-200">

  <h2 class="text-3xl font-bold mb-6">
    Säkra frisk luft i ditt hem
  </h2>

  <p class="text-gray-600 max-w-2xl mx-auto mb-10 text-lg">
    Boka professionell rengöring av ditt tilluftssystem i Sverige.
  </p>

  <div class="flex flex-wrap justify-center gap-6">
    <a
      href="/contact"
      class="px-8 py-4 border border-black rounded-lg hover:bg-black hover:text-white transition"
    >
      Kontakta oss
    </a>

    <a
      href="tel:+4620104544"
      class="px-8 py-4 border border-black rounded-lg hover:bg-black hover:text-white transition"
    >
      Ring 020-10 45 44
    </a>
  </div>

</section>

</main>

</BaseLayout>