---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Kontakta Oss | Ecoventilation"
  description="Kontakta Ecoventilation för professionell ventilationsservice, rensning och FTX-underhåll i Sverige."
>

<main class="max-w-[1200px] mx-auto px-6 py-20 font-sans text-gray-800">

  <!-- HERO -->
  <section class="mb-20 text-center">
    <h1 class="text-4xl md:text-5xl font-bold mb-6 text-[#2C3E50]">
      Kontakta Oss
    </h1>

    <p class="text-lg text-gray-600 max-w-2xl mx-auto leading-relaxed">
      Har du frågor eller vill boka service? Fyll i formuläret så återkommer vi inom 24 timmar.
    </p>
  </section>

  <!-- CONTACT SECTION -->
  <section class="flex flex-col lg:flex-row gap-12 items-start">

    <!-- LEFT SIDE -->
    <div class="flex-1 bg-white p-8 rounded-xl shadow-lg border border-[#ECF0F1]">

      <h2 class="text-2xl font-bold text-[#2C3E50] mb-6 pb-3 border-b border-gray-300">
        Kontaktinformation
      </h2>

      <div class="space-y-8 text-gray-700">

        <div>
          <p class="text-sm text-gray-500 uppercase tracking-wide mb-1">Telefon</p>
          <a href="tel:020104544"
             class="text-lg font-semibold hover:text-[#2C3E50] transition">
            020-10 45 44
          </a>
        </div>

        <div>
          <p class="text-sm text-gray-500 uppercase tracking-wide mb-1">E-post</p>
          <a href="mailto:kundservice@ecoventilation.se"
             class="text-lg font-semibold hover:text-[#2C3E50] transition">
            kundservice@ecoventilation.se
          </a>
        </div>

        <div>
          <p class="text-sm text-gray-500 uppercase tracking-wide mb-1">Adress</p>
          <p class="text-lg font-semibold">
            Petregatan 1, 802 50 Gävle
          </p>
        </div>

        <div>
          <p class="text-sm text-gray-500 uppercase tracking-wide mb-1">Öppettider</p>
          <p class="text-lg font-semibold">
            Måndag – Fredag: 10:00 – 14:00
          </p>
          <p class="text-sm text-gray-500">
            Lördag & Söndag: Stängt
          </p>
        </div>

      </div>

      <!-- Social -->
      <div class="mt-10 pt-6 border-t border-gray-200">
        <h3 class="text-lg font-semibold text-[#2C3E50] mb-4">
          Följ oss
        </h3>

        <div class="flex gap-6 text-gray-600">
          <a href="https://www.facebook.com/profile.php?id=61586090752435" class="hover:text-[#2C3E50] transition">Facebook</a>
          <a href="https://www.instagram.com/ecoventilation/" class="hover:text-[#2C3E50] transition">Instagram</a>
          <a href="#" class="hover:text-[#2C3E50] transition">TikTok</a>
          <a href="#" class="hover:text-[#2C3E50] transition">LinkedIn</a>
        </div>
      </div>

    </div>

    <!-- RIGHT SIDE -->
    <div class="flex-1 min-w-0">
      <ContactForm />
    </div>

  </section>

  <!-- CTA -->
  <section class="mt-24 text-center border-t pt-16">

    <h3 class="text-2xl font-semibold mb-6 text-[#2C3E50]">
      Behöver du snabb hjälp?
    </h3>

    <p class="text-gray-600 mb-8">
      Ring oss direkt så hjälper vi dig.
    </p>

    <a href="tel:020104544"
       class="inline-block bg-[#2C3E50] text-white px-10 py-4 rounded-lg font-semibold hover:bg-[#1f2f3a] transition shadow">
       Ring 020-10 45 44
    </a>

  </section>

</main>

</BaseLayout>