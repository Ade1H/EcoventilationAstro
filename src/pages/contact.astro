---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Kontakta Oss | Ecoventilation"
  description="Kontakta Ecoventilation för professionell ventilationsservice, rensning och FTX-underhåll i Sverige."
>

<main class="max-w-[1200px] mx-auto px-6 py-16 font-sans text-gray-800">

  <!-- ================= HERO ================= -->
  <section class="mb-16 text-center">
    <h1 class="text-4xl md:text-5xl font-bold mb-6">
      Kontakta Oss
    </h1>

    <p class="text-lg text-gray-600 max-w-2xl mx-auto">
      Har du frågor eller vill boka service? Fyll i formuläret eller använd våra kontaktuppgifter nedan.
    </p>
  </section>

  <!-- ================= GRID ================= -->
  <div class="grid lg:grid-cols-2 gap-12 items-start">

    <!-- ===== CONTACT INFO ===== -->
    <div class="space-y-10">

      <div>
        <h2 class="text-2xl font-semibold mb-4 border-b pb-2">
          Kontaktinformation
        </h2>

        <div class="space-y-6 text-gray-600">

          <div>
            <p class="font-medium text-gray-800">Telefon</p>
            <a href="tel:020104544" class="hover:underline">
              020-10 45 44
            </a>
          </div>

          <div>
            <p class="font-medium text-gray-800">E-post</p>
            <a href="mailto:kundservice@ecoventilation.se" class="hover:underline">
              kundservice@ecoventilation.se
            </a>
          </div>

          <div>
            <p class="font-medium text-gray-800">Adress</p>
            <p>Petregatan 1, 802 50 Gävle</p>
          </div>

          <div>
            <p class="font-medium text-gray-800">Öppettider</p>
            <p>Måndag – Fredag: 10:00 – 14:00</p>
            <p class="text-sm text-gray-500">Lördag & Söndag: Stängt</p>
          </div>

        </div>
      </div>

      <!-- ===== SOCIAL ===== -->
      <div>
        <h3 class="text-xl font-semibold mb-4">
          Sociala Medier
        </h3>

        <div class="flex gap-6">

          <a href="https://www.facebook.com/profile.php?id=61586090752435"
            class="text-gray-700 hover:text-black transition">
            Facebook
          </a>

          <a href="https://www.instagram.com/ecoventilation/"
            class="text-gray-700 hover:text-black transition">
            Instagram
          </a>

          <a href="https://tiktok.com/@ecoventilation"
            class="text-gray-700 hover:text-black transition">
            TikTok
          </a>

          <a href="https://linkedin.com/company/ecoventilation"
            class="text-gray-700 hover:text-black transition">
            LinkedIn
          </a>

        </div>
      </div>

    </div>

    <!-- ===== FORM ===== -->
    <div class="bg-white p-8 border border-gray-200 rounded-xl">
      <ContactForm />
    </div>

  </div>

  <!-- ================= SIMPLE CTA ================= -->
  <section class="mt-20 text-center border-t pt-16">

    <h3 class="text-2xl font-semibold mb-4">
      Behöver du snabb hjälp?
    </h3>

    <p class="text-gray-600 mb-6">
      Ring oss direkt så hjälper vi dig med ventilation och rensning.
    </p>

    <a href="tel:020104544"
       class="inline-block border border-black px-8 py-4 rounded-lg hover:bg-black hover:text-white transition">
       Ring 020-10 45 44
    </a>

  </section>

</main>

</BaseLayout>