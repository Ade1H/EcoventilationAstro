---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Rensning av Luft-Luft Värmepump – Sverige"
  description="Professionell rengöring av luft-luftvärmepumpar i Sverige. Vi förbättrar energieffektivitet, luftkvalitet och systemets livslängd."
>

<main class="max-w-[1200px] mx-auto px-6 py-20 text-gray-800">

<!-- ================= HERO ================= -->

<section class="text-center mb-20">
  <h1 class="text-4xl md:text-5xl font-bold mb-6">
    Rensning av Luft-Luft Värmepump
  </h1>

  <p class="text-lg text-gray-600 max-w-3xl mx-auto">
    Regelbunden service säkerställer maximal effekt, ren luft och lägre energiförbrukning.
  </p>
</section>

<!-- ================= IMAGES ================= -->

<section class="grid md:grid-cols-2 gap-8 mb-20">
  <img
    src="/images/ACmodern.webp"
    alt="Rengöring av luft-luft värmepump"
    class="rounded-xl w-full h-80 object-cover"
  />

  <img
    src="/images/AC.webp"
    alt="Professionell service av värmepump"
    class="rounded-xl w-full h-80 object-cover"
  />
</section>

<!-- ================= DESCRIPTION ================= -->

<section class="mb-20 space-y-8 text-lg text-gray-600 leading-relaxed">

  <h2 class="text-3xl font-semibold text-gray-800">
    Varför behövs rengöring?
  </h2>

  <p>
    En luft-luftvärmepump arbetar effektivt när filter, fläkt och
    värmeväxlare är rena. Smuts gör att systemet belastas och
    energiförbrukningen ökar.
  </p>

  <p>
    Regelbunden professionell service förbättrar luftkvaliteten,
    minskar ljudnivån och förlänger livslängden på systemet.
  </p>

</section>

<!-- ================= COMPONENTS ================= -->

<section class="mb-20">

  <h2 class="text-3xl font-semibold mb-10 text-center">
    Delar som rengörs
  </h2>

  <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">

    {[
      "Inomhusenhet – filter, fläkt & värmeväxlare",
      "Utomhusenhet – kondensor & fläkt",
      "Dränering – förebygger vattenproblem",
      "Elektronik & sensorer – stabil drift"
    ].map((item) => (

      <div class="border border-gray-200 rounded-xl p-6 text-lg">
        {item}
      </div>

    ))}

  </div>

</section>

<!-- ================= BENEFITS ================= -->

<section class="mb-20">

  <h2 class="text-3xl font-semibold mb-10 text-center">
    Fördelar med regelbunden service
  </h2>

  <div class="border border-gray-200 rounded-xl p-8">

    <ul class="space-y-4 text-lg text-gray-600 list-disc list-inside">
      <li>Lägre energikostnader</li>
      <li>Renare och bättre inomhusluft</li>
      <li>Tystare drift</li>
      <li>Längre livslängd</li>
    </ul>

  </div>

</section>

<!-- ================= WARNING ================= -->

<section class="mb-20">

  <h2 class="text-3xl font-semibold mb-10 text-center">
    Tecken på att service behövs
  </h2>

  <div class="border border-gray-200 rounded-xl p-8">

    <ul class="space-y-4 text-lg text-gray-600 list-disc list-inside">
      <li>Minskad värme- eller kylkapacitet</li>
      <li>Ovanliga lukter</li>
      <li>Ökad ljudnivå</li>
      <li>Kondens eller vattenläckage</li>
      <li>Ökad elförbrukning</li>
    </ul>

  </div>

</section>

<!-- ================= PROCESS ================= -->

<section class="mb-20">

  <h2 class="text-3xl font-semibold mb-10 text-center">
    Så går rengöringen till
  </h2>

  <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-6">

    {[
      "Inspektion",
      "Rengöring av filter & fläkt",
      "Rengöring av värmeväxlare",
      "Kontroll av dränering",
      "Funktionskontroll"
    ].map((step, index) => (

      <div class="border border-gray-200 rounded-xl p-6 text-center">

        <div class="w-12 h-12 mx-auto mb-4 border border-black rounded-full flex items-center justify-center font-semibold">
          {index + 1}
        </div>

        <p class="text-gray-700">{step}</p>

      </div>

    ))}

  </div>

</section>

<!-- ================= CTA ================= -->

<section class="text-center py-20 border-t border-gray-200">

  <h2 class="text-3xl font-bold mb-6">
    Håll din värmepump i toppskick
  </h2>

  <p class="text-gray-600 max-w-2xl mx-auto mb-10 text-lg">
    Boka professionell rengöring och optimera din värmepumps prestanda.
  </p>

  <div class="flex flex-wrap justify-center gap-6">
    <a
      href="/contact"
      class="px-8 py-4 border border-black rounded-lg hover:bg-black hover:text-white transition"
    >
      Kontakta oss
    </a>

    <a
      href="tel:+4620104544"
      class="px-8 py-4 border border-black rounded-lg hover:bg-black hover:text-white transition"
    >
      Ring 020-10 45 44
    </a>
  </div>

</section>

</main>

</BaseLayout>