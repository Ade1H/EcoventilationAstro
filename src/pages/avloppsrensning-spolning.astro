---
// File: src/pages/avlopp.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Avloppsspolning & Avloppsrensning i Sverige"
  description="Professionell avloppsspolning och avloppsrensning i hela Sverige. Våra certifierade tekniker hjälper med stopp, spolning och underhåll."
>

<main class="max-w-[1200px] mx-auto px-6 py-20 text-gray-800">

<!-- ================= HERO ================= -->

<section class="text-center mb-20">
  <h1 class="text-4xl md:text-5xl font-bold mb-6">
    Avloppsspolning & Avloppsrensning i Sverige
  </h1>

  <p class="text-lg text-gray-600 max-w-3xl mx-auto">
    Vi hjälper fastighetsägare och företag att rensa och spola avlopp snabbt,
    säkert och professionellt för att förebygga stopp och vattenskador.
  </p>
</section>

<!-- ================= IMAGES ================= -->

<section class="grid md:grid-cols-2 gap-8 mb-20">
  <img
    src="/images/AvloppBlumma.webp"
    alt="Avloppsrensning utförd av expert"
    class="rounded-xl w-full h-80 object-cover"
  />

  <img
    src="/images/avlopp2.webp"
    alt="Professionell avloppsspolning"
    class="rounded-xl w-full h-80 object-cover"
  />
</section>

<!-- ================= SERVICE SECTION ================= -->

<section class="mb-20 space-y-16">

  <div>
    <h2 class="text-3xl font-semibold mb-6">Avloppsrensning</h2>

    <div class="space-y-4 text-gray-600 leading-relaxed text-lg">
      <p>
        Avloppsrensning innebär att ta bort blockeringar och främmande föremål
        från rörsystemet. Vanliga orsaker är fett, hår och beläggningar som
        över tid minskar flödet.
      </p>

      <p>
        Typiska tecken är långsam avrinning, bubblande ljud eller dålig lukt.
        Vi använder professionell utrustning och rensvajer för att säkerställa
        ett långsiktigt resultat.
      </p>

      <p>
        Våra certifierade tekniker arbetar i hela Sverige och rekommenderar
        förebyggande rensning vart 3–4 år.
      </p>
    </div>
  </div>

  <div>
    <h2 class="text-3xl font-semibold mb-6">Avloppsspolning</h2>

    <div class="space-y-4 text-gray-600 leading-relaxed text-lg">
      <p>
        Avloppsspolning utförs med högtryck och vatten för att rengöra rören
        från fett, smuts och avlagringar.
      </p>

      <p>
        Metoden är effektiv för att förebygga akuta stopp och minska risken
        för kostsamma skador på rörsystemet.
      </p>

      <p>
        Regelbunden spolning rekommenderas var femte år för fastigheter och
        bostäder.
      </p>
    </div>
  </div>

</section>

<!-- ================= PROBLEMS ================= -->

<section class="mb-20">

  <h2 class="text-2xl font-semibold mb-8 text-center">
    Tecken på att avloppet behöver åtgärdas
  </h2>

  <ul class="grid md:grid-cols-2 gap-6 text-gray-700 text-lg">
    <li class="border border-gray-200 p-6 rounded-xl">
      Långsam avrinning i handfat, dusch eller golvbrunn
    </li>

    <li class="border border-gray-200 p-6 rounded-xl">
      Dålig eller unken lukt
    </li>

    <li class="border border-gray-200 p-6 rounded-xl">
      Återkommande stopp
    </li>

    <li class="border border-gray-200 p-6 rounded-xl">
      Bubblande ljud från rören
    </li>
  </ul>

</section>

<!-- ================= PREVENTION ================= -->

<section class="mb-20">

  <h2 class="text-2xl font-semibold mb-6 text-center">
    Förebyggande tips
  </h2>

  <div class="border border-gray-200 rounded-xl p-8 max-w-3xl mx-auto">
    <ul class="space-y-4 text-gray-600 text-lg list-disc list-inside">
      <li>Häll inte ut fett eller matrester i vasken</li>
      <li>Använd sil i diskho och dusch</li>
      <li>Rensa golvbrunnar regelbundet</li>
      <li>Undvik kemiska propplösare</li>
      <li>Planera spolning var femte år</li>
    </ul>
  </div>

</section>

<!-- ================= CTA ================= -->

<section class="text-center py-20 border-t border-gray-200">

  <h2 class="text-3xl font-bold mb-6">
    Behöver du hjälp med avloppet?
  </h2>

  <p class="text-gray-600 mb-10 max-w-2xl mx-auto">
    Kontakta oss för professionell avloppsspolning och rensning i hela Sverige.
  </p>

  <div class="flex flex-wrap justify-center gap-6">
    <a
      href="/contact"
      class="px-8 py-4 border border-black rounded-lg hover:bg-black hover:text-white transition"
    >
      Kontakta oss
    </a>

    <a
      href="tel:+4620104544"
      class="px-8 py-4 border border-black rounded-lg hover:bg-black hover:text-white transition"
    >
      Ring 020-10 45 44
    </a>
  </div>

</section>

</main>

</BaseLayout>