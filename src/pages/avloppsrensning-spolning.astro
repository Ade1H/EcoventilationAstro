---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <main class="bg-gray-50 min-h-screen px-4 py-16 md:py-24 font-sans">

    <!-- FAQ JSON-LD schema -->
    <script type="application/ld+json">
      {`
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Hur ofta behöver avloppet rensas?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Det beror på användning, men vanligtvis bör avlopp rensas minst en gång per år för att undvika stopp och dålig lukt."
            }
          },
          {
            "@type": "Question",
            "name": "Vad orsakar stopp i avloppet?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Vanliga orsaker är fett, hår, tvålrester och andra föremål som fastnar i rören."
            }
          },
          {
            "@type": "Question",
            "name": "Kan ni åtgärda akuta stopp?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja, vi erbjuder snabb och professionell avloppsrensning för akuta situationer över hela Sverige."
            }
          }
        ]
      }
      `}
    </script>

    <!-- Page Title -->
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-800 mb-4">
        Avloppsrensning & Spolning
      </h1>
      <p class="text-gray-600 text-lg md:text-xl">
        Stopp i avloppet kan orsaka lukt och översvämning. Vi åtgärdar problemen snabbt och professionellt över hela Sverige.
      </p>
    </div>

    <!-- Images -->
    <div class="max-w-6xl mx-auto grid gap-6 mb-12 grid-cols-1 md:grid-cols-2">
      <div class="rounded-xl overflow-hidden shadow-md">
        <img 
          src="/images/AvloppBlumma.webp" 
          alt="Avloppsrensning utförd av certifierad expert" 
          class="w-full h-64 md:h-80 object-cover"
        />
      </div>
      <div class="rounded-xl overflow-hidden shadow-md">
        <img 
          src="/images/avlopp2.webp" 
          alt="Spolning av avlopp med professionell utrustning" 
          class="w-full h-64 md:h-80 object-cover"
        />
      </div>
    </div>

    <!-- Description -->
    <section class="max-w-4xl mx-auto space-y-6 text-gray-700 mb-12">
      <p>
        Avloppsrensning innebär att man avlägsnar stopp och beläggningar som samlats i rören över tid. Vanliga orsaker är fett, hår, tvålrester och andra föremål.
      </p>
      <p>
        När avloppet inte rensas regelbundet kan problemen försvåra och leda till översvämning eller fuktskador.
      </p>
      <p>
        Typiska tecken på stopp är långsam avrinning, bubblande ljud och dålig lukt från avloppet.
      </p>
    </section>

    <!-- Tips -->
    <section class="max-w-4xl mx-auto bg-white p-6 rounded-xl shadow-md mb-8">
      <h2 class="text-2xl font-semibold text-gray-800 mb-4">Förebyggande tips</h2>
      <ul class="list-disc list-inside space-y-2 text-gray-600">
        <li>Undvik att hälla fett och matrester i avloppet</li>
        <li>Använd sil i diskho, handfat och dusch</li>
        <li>Rensa golvbrunnar regelbundet</li>
      </ul>
    </section>

    <!-- Warning Signs -->
    <section class="max-w-4xl mx-auto bg-white p-6 rounded-xl shadow-md mb-12">
      <h2 class="text-2xl font-semibold text-gray-800 mb-4">När behöver avloppet rensas?</h2>
      <ul class="list-disc list-inside space-y-2 text-gray-600">
        <li>Långsam avrinning i handfat eller dusch</li>
        <li>Dålig eller unken lukt</li>
        <li>Återkommande stopp</li>
        <li>Bubblande ljud från rören</li>
      </ul>
    </section>

    <!-- CTA -->
    <section class="max-w-4xl mx-auto bg-gray-800 text-white text-center p-8 rounded-xl shadow-md">
      <h3 class="text-2xl font-semibold mb-2">Behöver du hjälp med avloppet?</h3>
      <p class="mb-4">Vi hjälper dig snabbt och professionellt.</p>
      <a
        href="/contact"
        class="btn-primary inline-block bg-white text-[#2C3E50] font-bold py-4 px-8 rounded-lg hover:bg-gray-100 hover:text-green-800 transition duration-300 text-lg"
      >
        Kontakta oss
      </a>
    </section>

  </main>
</BaseLayout>
