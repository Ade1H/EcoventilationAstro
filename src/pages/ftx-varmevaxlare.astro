---
// File: src/pages/ftx.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="FTX & Värmeväxlare – Service och Underhåll i Sverige"
  description="Professionell FTX-service och underhåll av värmeväxlare i Sverige. Vi hjälper fastigheter och bostäder med filterbyte, rengöring och energieffektiv optimering."
>

<main class="max-w-[1200px] mx-auto px-6 py-20 text-gray-800">

<!-- ================= HERO ================= -->

<section class="text-center mb-20">
  <h1 class="text-4xl md:text-5xl font-bold mb-6">
    FTX & Värmeväxlare – Service och Underhåll
  </h1>

  <p class="text-lg text-gray-600 max-w-3xl mx-auto">
    FTX-system återvinner värme och förbättrar luftkvaliteten.
    Regelbunden service säkerställer energieffektiv drift och stabil inomhuskomfort.
  </p>
</section>

<!-- ================= IMAGES ================= -->

<section class="grid md:grid-cols-2 gap-8 mb-20">
  <img
    src="/images/FTX.webp"
    alt="FTX system"
    class="rounded-xl w-full h-80 object-cover"
  />

  <img
    src="/images/ftxPic.webp"
    alt="FTX värmeväxlare i ventilationssystem"
    class="rounded-xl w-full h-80 object-cover"
  />
</section>

<!-- ================= WHAT IS FTX ================= -->

<section class="mb-20">

  <h2 class="text-3xl font-semibold mb-6">
    Vad är en FTX / värmeväxlare?
  </h2>

  <div class="space-y-6 text-lg text-gray-600 leading-relaxed">
    <p>
      FTX står för från- och tilluft med värmeåtervinning.
      Systemet återvinner värme från den utgående luften och förvärmer
      den friska luften som tas in i byggnaden.
    </p>

    <p>
      Detta minskar energiförbrukningen och ger ett jämnt och behagligt
      inomhusklimat året runt.
    </p>

    <p>
      Systemet består av separata luftkanaler och en värmeväxlare som
      möjliggör effektiv energiöverföring mellan luftströmmarna.
    </p>
  </div>

</section>

<!-- ================= MAINTENANCE ================= -->

<section class="mb-20">

  <h2 class="text-3xl font-semibold mb-8">
    Underhåll och rengöring av FTX
  </h2>

  <div class="border border-gray-200 rounded-xl p-10">
    <ol class="space-y-5 text-gray-600 text-lg list-decimal list-inside">
      <li>
        <strong>Skapa en underhållsplan</strong> – Planera regelbunden inspektion och service.
      </li>

      <li>
        <strong>Inspektion</strong> – Kontroll av komponenter, läckor och slitage.
      </li>

      <li>
        <strong>Filterbyte</strong> – Filter bör rengöras eller bytas var 3–6 månad.
      </li>

      <li>
        <strong>Djupservice</strong> – Grundlig rengöring rekommenderas vart 3–5 år.
      </li>
    </ol>
  </div>

</section>

<!-- ================= BENEFITS ================= -->

<section class="mb-20">

  <h2 class="text-3xl font-semibold mb-8 text-center">
    Fördelar med regelbunden FTX-service
  </h2>

  <div class="grid md:grid-cols-2 gap-6">

    {[
      "Effektiv värmeåtervinning och energibesparing",
      "Förbättrad luftkvalitet",
      "Stabil inomhustemperatur",
      "Förebygger fukt och mögel",
      "Längre livslängd på systemet"
    ].map((item) => (
      <div class="border border-gray-200 rounded-xl p-6 text-lg">
        {item}
      </div>
    ))}

  </div>

</section>

<!-- ================= WARNING ================= -->

<section class="mb-20">

  <h2 class="text-3xl font-semibold mb-8 text-center">
    När behöver du service?
  </h2>

  <div class="border border-gray-200 rounded-xl p-8">
    <ul class="space-y-4 text-gray-600 text-lg list-disc list-inside">
      <li>Försämrad luftkvalitet</li>
      <li>Ökad energiförbrukning</li>
      <li>Ovanliga ljud från aggregatet</li>
      <li>Ojämn temperatur</li>
    </ul>
  </div>

</section>

<!-- ================= CTA ================= -->

<section class="text-center py-20 border-t border-gray-200">

  <h2 class="text-3xl font-bold mb-6">
    Behöver du FTX-service?
  </h2>

  <p class="text-gray-600 max-w-2xl mx-auto mb-10 text-lg">
    Kontakta oss för filterbyte, rengöring och professionell service av ditt ventilationssystem.
  </p>

  <div class="flex flex-wrap justify-center gap-6">
    <a
      href="/contact"
      class="px-8 py-4 border border-black rounded-lg hover:bg-black hover:text-white transition"
    >
      Kontakta oss
    </a>

    <a
      href="tel:+4620104544"
      class="px-8 py-4 border border-black rounded-lg hover:bg-black hover:text-white transition"
    >
      Ring 020-10 45 44
    </a>
  </div>

</section>

</main>

</BaseLayout>