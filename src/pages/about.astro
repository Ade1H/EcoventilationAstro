---
// File: src/pages/about.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Map from '../components/Map.jsx';
---

<BaseLayout
  title="Om Oss | Ecoventilation"
  description="Ecoventilation – Ventilationsspecialister i Gävle och Sverige sedan 2018."
>

<main class="max-w-[1200px] mx-auto px-6 py-20 text-gray-800">

  <!-- ================= HERO ================= -->
  <section class="mb-20 text-center">
    <h1 class="text-4xl md:text-6xl font-bold mb-6">
      Ecoventilation
    </h1>

    <p class="text-xl text-gray-600 max-w-3xl mx-auto">
      Ventilationsspecialister med fokus på kvalitet, hållbarhet och professionell service sedan 2018.
    </p>
  </section>

  <!-- ================= INTRO ================= -->
  <section class="grid md:grid-cols-2 gap-16 items-center mb-24">

    <div>
      <h2 class="text-3xl font-semibold mb-6">
        Vår historia
      </h2>

      <p class="text-gray-600 text-lg leading-relaxed mb-4">
        Vi är ett Gävlebaserat företag som specialiserat oss på
        professionella ventilationslösningar för fastigheter,
        bostadsrättsföreningar och företag i hela Sverige.
      </p>

      <p class="text-gray-600 text-lg leading-relaxed">
        Vårt mål är att skapa energieffektiva och hälsosamma
        inomhusmiljöer med långsiktiga och hållbara lösningar.
      </p>
    </div>

    <div class="rounded-xl overflow-hidden">
      <img
        src="/images/ventbild3.webp"
        alt="Ecoventilation team"
        class="w-full h-full object-cover"
      />
    </div>

  </section>

  <!-- ================= VALUES ================= -->
  <section class="mb-24">

    <h2 class="text-3xl font-semibold text-center mb-12">
      Våra värderingar
    </h2>

    <div class="grid md:grid-cols-3 gap-10">

      {[
        {
          title: "Kvalitet",
          text: "Vi arbetar med precision och använder beprövade metoder för långsiktiga resultat."
        },
        {
          title: "Hållbarhet",
          text: "Vi prioriterar energieffektiva lösningar som minskar miljöpåverkan."
        },
        {
          title: "Personlig Service",
          text: "Vi anpassar varje projekt efter kundens behov och fastighetens krav."
        }
      ].map((item) => (

        <div class="border border-gray-200 p-8 rounded-xl hover:border-black transition">

          <h3 class="text-xl font-semibold mb-4">
            {item.title}
          </h3>

          <p class="text-gray-600 leading-relaxed text-sm">
            {item.text}
          </p>

        </div>

      ))}

    </div>

  </section>

  <!-- ================= LOCATION ================= -->
  <section class="mb-24">

    <h2 class="text-3xl font-semibold text-center mb-10">
      Besök vårt kontor
    </h2>

    <div class="grid md:grid-cols-2 gap-12 items-start">

      <!-- INFO -->
      <div class="space-y-8">

        <div>
          <h3 class="font-medium mb-2">Adress</h3>
          <p class="text-gray-600">Petregatan 1, 802 50 Gävle</p>
        </div>

        <div>
          <h3 class="font-medium mb-2">Telefon</h3>
          <a href="tel:020104544" class="text-gray-600 hover:underline">
            020-10 45 44
          </a>
        </div>

        <div>
          <h3 class="font-medium mb-2">E-post</h3>
          <a href="mailto:kundservice@ecoventilation.se" class="text-gray-600 hover:underline">
            kundservice@ecoventilation.se
          </a>
        </div>

        <div>
          <h3 class="font-medium mb-2">Öppettider</h3>
          <p class="text-gray-600">
            Måndag – Fredag: 08:00 – 17:00<br/>
            Lördag: 10:00 – 14:00<br/>
            Söndag: Stängt
          </p>
        </div>

      </div>

      <!-- MAP -->
      <div class="rounded-xl overflow-hidden border border-gray-200">
        <Map
          client:only="react"
          lat={60.674}
          lng={17.141}
          markerText="Ecoventilation - Gävle"
        />
      </div>

    </div>

  </section>

  <!-- ================= CTA ================= -->
  <section class="text-center border-t pt-20">

    <h2 class="text-3xl font-semibold mb-6">
      Vill du arbeta med oss?
    </h2>

    <p class="text-gray-600 max-w-2xl mx-auto mb-8">
      Kontakta oss för en professionell genomgång av ditt ventilationsprojekt.
    </p>

    <a
      href="/contact"
      class="inline-block border border-black px-10 py-4 rounded-lg hover:bg-black hover:text-white transition"
    >
      Kontakta oss
    </a>

  </section>

</main>

</BaseLayout>